@page
@model InventoryPlatform.Web.Pages.Categories.DetailsModel

<h1>Category Details</h1>

<div class="card">
    <div class="card-body">

        <dl class="row">


            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Category.Name</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Category.Description</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @(Model.Category.IsActive ? "Active" : "Inactive")
            </dd>

        </dl>

        <div class="mt-4">

            <a asp-page="Index"
               class="btn btn-secondary">
                Back
            </a>

            <a asp-page="Edit"
               asp-route-id="@Model.Category.Id"
               class="btn btn-primary">
                Edit
            </a>

        </div>

    </div>
</div>