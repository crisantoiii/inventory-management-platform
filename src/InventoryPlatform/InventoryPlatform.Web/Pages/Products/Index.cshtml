@page
@model InventoryPlatform.Web.Pages.Products.IndexModel
@{
    var start = (Model.Products.Page - 1) * Model.Products.PageSize + 1;

    var end = Math.Min(
        Model.Products.Page * Model.Products.PageSize,
        Model.Products.TotalCount);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Products</h1>

    <a asp-page="Create"
       class="btn btn-primary">
        Add Product
    </a>
</div>
@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show"
         role="alert">

        @Model.SuccessMessage

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>
    </div>
}
<form method="get" class="row g-3 mb-3">

    <div class="col-md-4">
        <input asp-for="Filter.Search"
               class="form-control"
               placeholder="Search SKU or Name..." />
    </div>

    <div class="col-auto">
        <button class="btn btn-primary">
            Search
        </button>
    </div>

    <div class="col-auto">
        <a asp-page="Index"
           class="btn btn-outline-secondary">
            Clear
        </a>
    </div>

</form>

<p class="text-muted">
    Showing @start–@end of @Model.Products.TotalCount products
</p>

@if (!Model.Products.Items.Any())
{
    <div class="alert alert-info">
        No products found.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>SKU</th>
                <th>Name</th>
                <th>Cost</th>
                <th>Selling</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var product in Model.Products.Items)
            {
                <tr>
                    <td>@product.Sku</td>
                    <td>
                        <a asp-page="Details"
                           asp-route-id="@product.Id">
                            @product.Name
                        </a>
                    </td>
                    <td>@product.CostPrice</td>
                    <td>@product.SellingPrice</td>
                    <td>@(product.IsActive ? "Active" : "Inactive")</td>
                    <td class="text-end">

                        <div class="btn-group" role="group">

                            <a asp-page="Details"
                               asp-route-id="@product.Id"
                               class="btn btn-sm btn-outline-secondary">
                                Details
                            </a>

                            <a asp-page="Edit"
                               asp-route-id="@product.Id"
                               class="btn btn-sm btn-outline-primary">
                                Edit
                            </a>

                            <a asp-page="Deactivate"
                               asp-route-id="@product.Id"
                               class="btn btn-sm btn-outline-danger">
                                Deactivate
                            </a>

                        </div>

                    </td>
                </tr>
            }

        </tbody>
    </table>
    <nav>

        <ul class="pagination">

            @if (Model.Products.HasPreviousPage)
            {
                <li class="page-item">

                    <a class="page-link"
                       href="?Page=@(Model.Products.Page - 1)&Search=@Model.Filter.Search">
                        Previous
                    </a>

                </li>
            }

            @for (int i = 1; i <= Model.Products.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Products.Page ? "active" : "")">
                    <a class="page-link"
                       href="?Page=@i&Search=@Model.Filter.Search">
                        @i
                    </a>

                </li>
            }

            @if (Model.Products.HasNextPage)
            {
                <li class="page-item">

                    <a class="page-link"
                       href="?Page=@(Model.Products.Page + 1)&Search=@Model.Filter.Search">
                        Next
                    </a>

                </li>
            }

        </ul>

    </nav>
}

