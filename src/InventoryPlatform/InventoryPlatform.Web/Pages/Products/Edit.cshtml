@page "{id:int}"
@model InventoryPlatform.Web.Pages.Products.EditModel

<h1>Edit Product</h1>

<form method="post">
    <input asp-for="Product.Id" type="hidden" />

    <div class="mb-3">
        <label asp-for="Product.Name" class="form-label"></label>
        <input asp-for="Product.Name" class="form-control" />
        <span asp-validation-for="Product.Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Product.Unit" class="form-label"></label>
        <input asp-for="Product.Unit" class="form-control" />
        <span asp-validation-for="Product.Unit" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Product.CostPrice" class="form-label"></label>
        <input asp-for="Product.CostPrice"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Product.SellingPrice"
               class="form-label"></label>
        <input asp-for="Product.SellingPrice"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Product.Barcode" class="form-label"></label>
        <input asp-for="Product.Barcode"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Product.Description"
               class="form-label"></label>
        <input asp-for="Product.Description"
               class="form-control" />
    </div>

    <button class="btn btn-primary">
        Save
    </button>

    <a asp-page="Index"
       class="btn btn-secondary">
        Cancel
    </a>
</form>