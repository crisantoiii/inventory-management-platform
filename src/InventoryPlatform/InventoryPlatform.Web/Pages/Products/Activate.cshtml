@page "{id:int}"
@model InventoryPlatform.Web.Pages.Products.ActivateModel

<h1>Activate Product</h1>

<div class="alert alert-success">
    <strong>Warning!</strong>
    This product will become active and will
    be available for new transactions.
</div>

<dl class="row">
    <dt class="col-sm-3">SKU</dt>
    <dd class="col-sm-9">@Model.Product.Sku</dd>

    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Product.Name</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">
        @(Model.Product.IsActive ? "Active" : "Inactive")
    </dd>
</dl>

<form method="post">

    <input asp-for="ActivateRequest.Id" type="hidden" />

    <button type="submit" class="btn btn-primary">
        Activate
    </button>

    <a asp-page="Index" class="btn btn-secondary">
        Cancel
    </a>

</form>