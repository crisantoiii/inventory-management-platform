@page "{id:int}"
@model InventoryPlatform.Web.Pages.Units.DeactivateModel

<h1>Deactivate Unit</h1>

<div class="alert alert-warning">
    <strong>Warning!</strong>
    This category will become inactive and will no longer
    be available for new transactions.
</div>

<dl class="row">
    <dt class="col-sm-3">Code</dt>
    <dd class="col-sm-9">@Model.Unit.Code</dd>

    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Unit.Name</dd>

    <dt class="col-sm-3">Symbol</dt>
    <dd class="col-sm-9">@Model.Unit.Symbol</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">
        @(Model.Unit.IsActive ? "Active" : "Inactive")
    </dd>
</dl>

<form method="post">

    <input asp-for="DeactivateRequest.Id" type="hidden" />

    <button type="submit" class="btn btn-danger">
        Deactivate
    </button>

    <a asp-page="Index" class="btn btn-secondary">
        Cancel
    </a>

</form>