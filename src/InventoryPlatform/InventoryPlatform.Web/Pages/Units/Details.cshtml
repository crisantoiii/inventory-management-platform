@page
@model InventoryPlatform.Web.Pages.Units.DetailsModel

<h1>Unit Details</h1>

<div class="card">
    <div class="card-body">

        <dl class="row">

            <dt class="col-sm-3">Code</dt>
            <dd class="col-sm-9">@Model.Unit.Code</dd>

            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Unit.Name</dd>

            <dt class="col-sm-3">Symbol</dt>
            <dd class="col-sm-9">@Model.Unit.Symbol</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @(Model.Unit.IsActive ? "Active" : "Inactive")
            </dd>

        </dl>

        <div class="mt-4">

            <a asp-page="Index"
               class="btn btn-secondary">
                Back
            </a>

            <a asp-page="Edit"
               asp-route-id="@Model.Unit.Id"
               class="btn btn-primary">
                Edit
            </a>

        </div>

    </div>
</div>