@page
@model InventoryPlatform.Web.Pages.Units.CreateModel

<h1>Create Unit</h1>

<form method="post">

    <div asp-validation-summary="ModelOnly"
         class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Unit.Code"
               class="form-label"></label>
        <input asp-for="Unit.Code"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Unit.Name" class="form-label"></label>
        <input asp-for="Unit.Name" class="form-control" />
        <span asp-validation-for="Unit.Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Unit.Symbol"
               class="form-label"></label>
        <input asp-for="Unit.Symbol"
               class="form-control" />
    </div>

    <button class="btn btn-primary">
        Save
    </button>

    <a asp-page="Index"
       class="btn btn-secondary">
        Cancel
    </a>

</form>