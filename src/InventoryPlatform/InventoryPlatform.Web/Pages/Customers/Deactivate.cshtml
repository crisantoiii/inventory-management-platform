@page "{id:int}"
@model InventoryPlatform.Web.Pages.Customers.DeactivateModel

<h1>Deactivate Customer</h1>

<div class="alert alert-warning">
    <strong>Warning!</strong>
    This customer will become inactive and will no longer
    be available for new transactions.
</div>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Customer.Name</dd>

    <dt class="col-sm-3">Contact Person</dt>
    <dd class="col-sm-9">@Model.Customer.ContactPerson</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Customer.Email</dd>

    <dt class="col-sm-3">Phone</dt>
    <dd class="col-sm-9">@Model.Customer.Phone</dd>

    <dt class="col-sm-3">Address</dt>
    <dd class="col-sm-9">@Model.Customer.Address</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">
        @(Model.Customer.IsActive ? "Active" : "Inactive")
    </dd>
</dl>

<form method="post">

    <input asp-for="DeactivateRequest.Id" type="hidden" />

    <button type="submit" class="btn btn-danger">
        Deactivate
    </button>

    <a asp-page="Index" class="btn btn-secondary">
        Cancel
    </a>

</form>