@page "{id:int}"
@model InventoryPlatform.Web.Pages.Suppliers.ActivateModel

<h1>Activate Product</h1>

<div class="alert alert-success">
    <strong>Warning!</strong>
    This supplier will become active and will
    be available for new transactions.
</div>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Supplier.Name</dd>

    <dt class="col-sm-3">Contact Person</dt>
    <dd class="col-sm-9">@Model.Supplier.ContactPerson</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Supplier.Email</dd>

    <dt class="col-sm-3">Phone</dt>
    <dd class="col-sm-9">@Model.Supplier.Phone</dd>

    <dt class="col-sm-3">Address</dt>
    <dd class="col-sm-9">@Model.Supplier.Address</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">
        @(Model.Supplier.IsActive ? "Active" : "Inactive")
    </dd>
</dl>

<form method="post">

    <input asp-for="ActivateRequest.Id" type="hidden" />

    <button type="submit" class="btn btn-primary">
        Activate
    </button>

    <a asp-page="Index" class="btn btn-secondary">
        Cancel
    </a>

</form>